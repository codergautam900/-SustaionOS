MONGO_URI=your_mongodb_connection_string
PORT=5000
JWT_SECRET=your_jwt_secret

# You can keep multiple origins separated by commas during demo prep.
# Example:
# CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Self-hosted Ollama mode for hackathon demos.
# If you expose Ollama from your laptop/PC with a tunnel, keep this as `ollama`.
AI_PROVIDER=ollama

# Self-hosted Ollama endpoint
# Local example:
# OLLAMA_URL=http://localhost:11434/api/chat
# Free tunnel example:
# OLLAMA_URL=https://your-random-subdomain.trycloudflare.com/api/chat
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2:1b

# Optional OpenAI
# Leave empty if hackathon rules do not allow external AI APIs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_URL=https://api.openai.com/v1/chat/completions

# Optional Gemini
# Leave empty if hackathon rules do not allow external AI APIs.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models

# Python ML bridge
ML_SERVICE_URL=http://localhost:8000
